{
  "name": "floorai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "convex dev --start \"next dev\"",
    "dev:app": "next dev",
    "dev:turbo": "convex dev --start \"next dev --turbopack\"",
    "dev:convex": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "convex run seed:seedAll",
    "eval:validate": "python -m agents.retail_ops.evaluate --validate-only",
    "eval:goldens": "python -m agents.retail_ops.evaluate",
    "eval:live": "convex run eval:runEval",
    "eval:live:local": "node scripts/live-eval.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.63",
    "@convex-dev/agent": "^0.6.1",
    "@google/genai": "^1.50.1",
    "ai": "^6.0.160",
    "convex": "^1.17.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
